page {
  background: #f6f7f2;
  color: #20231d;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.top {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
  margin-bottom: 28rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 10rpx;
  color: #6e746a;
  font-size: 26rpx;
  line-height: 1.5;
}

.upload-btn,
.empty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0 24rpx;
  margin: 0;
  min-width: 148rpx;
  height: 76rpx;
  line-height: 1;
  border-radius: 10rpx;
  color: #fff;
  background: #244638;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.upload-btn::after,
.empty-btn::after {
  border: 0;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.photo-card {
  overflow: hidden;
  background: #fff;
  border: 1rpx solid #e7e8df;
  border-radius: 12rpx;
}

.photo {
  display: block;
  width: 100%;
  height: 280rpx;
  background: #dfe2d6;
}

.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx;
}

.status {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #5f673b;
  background: #eef2dc;
}

.status-used {
  color: #60646c;
  background: #eef0f4;
}

.status-processing {
  color: #87620b;
  background: #fff3cf;
}

.status-failed {
  color: #9a352d;
  background: #ffe7e2;
}

.delete {
  color: #9a352d;
  font-size: 24rpx;
}

.empty {
  padding: 68rpx 36rpx;
  text-align: center;
  background: #fff;
  border: 1rpx solid #e7e8df;
  border-radius: 14rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-desc {
  margin: 16rpx 0 30rpx;
  color: #72786d;
  font-size: 26rpx;
  line-height: 1.5;
}
