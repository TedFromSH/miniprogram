page {
  background: #f6f7f2;
  color: #20231d;
}

.page {
  min-height: 100vh;
}

.cover-wrap {
  position: relative;
}

.cover {
  display: block;
  width: 100%;
  height: 560rpx;
  background: #dfe2d6;
}

.cover-actions {
  position: absolute;
  right: 24rpx;
  bottom: 52rpx;
  display: flex;
  gap: 12rpx;
}

.cover-action {
  padding: 8rpx 16rpx;
  color: #fff;
  background: rgba(32, 35, 29, 0.62);
  border-radius: 999rpx;
  font-size: 22rpx;
}

.cover-action:active {
  background: rgba(32, 35, 29, 0.78);
}

.article {
  margin-top: -32rpx;
  padding: 36rpx 28rpx 64rpx;
  background: #f6f7f2;
  border-radius: 24rpx 24rpx 0 0;
  position: relative;
}

.date {
  color: #767b71;
  font-size: 24rpx;
}

.title {
  margin-top: 12rpx;
  font-size: 46rpx;
  line-height: 1.25;
  font-weight: 700;
}

.summary {
  margin-top: 20rpx;
  color: #53594f;
  font-size: 29rpx;
  line-height: 1.65;
}

.panel-list {
  margin-top: 36rpx;
}

.processing-box {
  margin-top: 28rpx;
  padding: 26rpx;
  color: #244638;
  background: #eef5e8;
  border: 1rpx solid #d5e2ca;
  border-radius: 14rpx;
}

.processing-title {
  font-size: 30rpx;
  font-weight: 700;
}

.processing-desc {
  margin-top: 10rpx;
  color: #5d6a57;
  font-size: 26rpx;
  line-height: 1.55;
}

.panel {
  margin-bottom: 20rpx;
  padding: 28rpx;
  background: #fff;
  border: 1rpx solid #e7e8df;
  border-radius: 14rpx;
}

.panel-index {
  color: #6c7f45;
  font-size: 24rpx;
  font-weight: 700;
}

.caption {
  margin-top: 14rpx;
  font-size: 31rpx;
  line-height: 1.5;
  font-weight: 600;
}

.dialogue {
  margin-top: 14rpx;
  padding: 20rpx 22rpx;
  color: #3f463d;
  background: #f3f5ec;
  border-radius: 10rpx;
  font-size: 27rpx;
  line-height: 1.6;
}

.ending {
  margin-top: 28rpx;
  padding: 26rpx;
  color: #fff;
  background: #244638;
  border-radius: 14rpx;
  font-size: 29rpx;
  line-height: 1.6;
}

.debug-box {
  margin-top: 24rpx;
  padding: 22rpx;
  color: #7a5a16;
  background: #fff7df;
  border: 1rpx solid #efdca8;
  border-radius: 12rpx;
  font-size: 23rpx;
  line-height: 1.55;
  word-break: break-all;
}

.debug-title {
  margin-bottom: 8rpx;
  font-weight: 700;
}

.debug-row {
  margin-top: 4rpx;
}

.debug-action {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin-top: 18rpx;
  padding: 0 20rpx;
  height: 68rpx;
  line-height: 1;
  color: #7a5a16;
  background: #fff;
  border: 1rpx solid #efdca8;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.debug-action::after {
  border: 0;
}

.copy-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 0 24rpx;
  margin-top: 32rpx;
  height: 88rpx;
  line-height: 1;
  color: #244638;
  background: #fff;
  border: 1rpx solid #cdd2c1;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.copy-btn::after {
  border: 0;
}

.loading {
  padding-top: 180rpx;
  text-align: center;
  color: #74786d;
  font-size: 28rpx;
}
