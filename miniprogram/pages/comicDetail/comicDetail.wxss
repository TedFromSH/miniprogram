page {
  background: #f6f7f2;
  color: #20231d;
}

.page {
  min-height: 100vh;
}

.cover {
  display: block;
  width: 100%;
  height: 560rpx;
  background: #dfe2d6;
}

.article {
  margin-top: -32rpx;
  padding: 36rpx 28rpx 64rpx;
  background: #f6f7f2;
  border-radius: 24rpx 24rpx 0 0;
  position: relative;
}

.date {
  color: #767b71;
  font-size: 24rpx;
}

.title {
  margin-top: 12rpx;
  font-size: 46rpx;
  line-height: 1.25;
  font-weight: 700;
}

.summary {
  margin-top: 20rpx;
  color: #53594f;
  font-size: 29rpx;
  line-height: 1.65;
}

.panel-list {
  margin-top: 36rpx;
}

.panel {
  margin-bottom: 20rpx;
  padding: 28rpx;
  background: #fff;
  border: 1rpx solid #e7e8df;
  border-radius: 14rpx;
}

.panel-index {
  color: #6c7f45;
  font-size: 24rpx;
  font-weight: 700;
}

.caption {
  margin-top: 14rpx;
  font-size: 31rpx;
  line-height: 1.5;
  font-weight: 600;
}

.dialogue {
  margin-top: 14rpx;
  padding: 20rpx 22rpx;
  color: #3f463d;
  background: #f3f5ec;
  border-radius: 10rpx;
  font-size: 27rpx;
  line-height: 1.6;
}

.ending {
  margin-top: 28rpx;
  padding: 26rpx;
  color: #fff;
  background: #244638;
  border-radius: 14rpx;
  font-size: 29rpx;
  line-height: 1.6;
}

.copy-btn {
  margin-top: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  color: #244638;
  background: #fff;
  border: 1rpx solid #cdd2c1;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.loading {
  padding-top: 180rpx;
  text-align: center;
  color: #74786d;
  font-size: 28rpx;
}
