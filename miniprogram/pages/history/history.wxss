page {
  background: #f6f7f2;
  color: #20231d;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 10rpx;
  color: #6e746a;
  font-size: 26rpx;
  line-height: 1.5;
}

.list {
  margin-top: 28rpx;
}

.comic-card {
  display: flex;
  overflow: hidden;
  min-height: 190rpx;
  margin-bottom: 18rpx;
  background: #fff;
  border: 1rpx solid #e7e8df;
  border-radius: 12rpx;
}

.cover-wrap {
  position: relative;
  width: 190rpx;
  height: 190rpx;
  flex: none;
}

.cover {
  width: 100%;
  height: 100%;
  background: #dfe2d6;
}

.status-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  padding: 6rpx 12rpx;
  color: #244638;
  background: rgba(255, 247, 223, 0.94);
  border: 1rpx solid #efdca8;
  border-radius: 8rpx;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1;
}

.body {
  min-width: 0;
  flex: 1;
  padding: 22rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.date {
  color: #767b71;
  font-size: 23rpx;
}

.status-text {
  flex: none;
  color: #7a5a16;
  font-size: 22rpx;
}

.comic-title {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.summary {
  margin-top: 10rpx;
  color: #5d6358;
  font-size: 25rpx;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.empty {
  margin-top: 28rpx;
  padding: 68rpx 36rpx;
  text-align: center;
  background: #fff;
  border: 1rpx solid #e7e8df;
  border-radius: 14rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 16rpx;
  color: #72786d;
  font-size: 26rpx;
  line-height: 1.5;
}
