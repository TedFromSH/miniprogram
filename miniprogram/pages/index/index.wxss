page {
  background: #f6f7f2;
  color: #20231d;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.hero {
  min-height: 300rpx;
  display: flex;
  align-items: flex-end;
  padding: 36rpx 32rpx;
  box-sizing: border-box;
  color: #fff;
  background: linear-gradient(135deg, #244638 0%, #6c7f45 100%);
  border-radius: 16rpx;
}

.eyebrow {
  font-size: 24rpx;
  opacity: 0.82;
  margin-bottom: 16rpx;
}

.title {
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 700;
}

.subtitle {
  width: 560rpx;
  max-width: 100%;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.55;
  opacity: 0.86;
}

.notice {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 12rpx;
  background: #fff1df;
  color: #955800;
  font-size: 26rpx;
  line-height: 1.5;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-item {
  padding: 28rpx 12rpx;
  text-align: center;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #e7e8df;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 8rpx;
  color: #74786d;
  font-size: 24rpx;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 28rpx;
}

.primary-btn,
.secondary-btn,
.inline-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.primary-btn {
  color: #fff;
  background: #244638;
}

.secondary-btn,
.inline-btn {
  color: #244638;
  background: #fff;
  border: 1rpx solid #cdd2c1;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 44rpx 4rpx 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
}

.section-link {
  color: #5f7042;
  font-size: 26rpx;
}

.comic-card {
  overflow: hidden;
  background: #fff;
  border-radius: 14rpx;
  border: 1rpx solid #e7e8df;
}

.comic-cover {
  width: 100%;
  height: 360rpx;
  display: block;
  background: #dfe2d6;
}

.comic-body {
  padding: 28rpx;
}

.comic-date {
  color: #767b71;
  font-size: 24rpx;
}

.comic-title {
  margin-top: 10rpx;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 700;
}

.comic-summary {
  margin-top: 14rpx;
  color: #5d6358;
  font-size: 28rpx;
  line-height: 1.55;
}

.empty-state {
  padding: 56rpx 32rpx;
  text-align: center;
  background: #fff;
  border: 1rpx solid #e7e8df;
  border-radius: 14rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  margin: 14rpx 0 28rpx;
  color: #73786e;
  font-size: 26rpx;
  line-height: 1.5;
}
