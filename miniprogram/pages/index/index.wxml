<view class="page">
  <view class="hero">
    <view>
      <view class="eyebrow">每日照片漫画</view>
      <view class="title">从照片池里抽出今天的故事</view>
      <view class="subtitle">先上传一批照片，系统每天随机选择一张生成漫画脚本。</view>
    </view>
  </view>

  <view wx:if="{{initError}}" class="notice">
    {{initError}}
  </view>

  <view class="stats">
    <view class="stat-item">
      <view class="stat-value">{{stats.unused}}</view>
      <view class="stat-label">待抽取</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{stats.used}}</view>
      <view class="stat-label">已生成</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{stats.failed}}</view>
      <view class="stat-label">失败</view>
    </view>
  </view>

  <view class="action-row">
    <button class="primary-btn" loading="{{generating}}" bindtap="generateTodayComic">
      生成今日漫画
    </button>
    <button class="secondary-btn" bindtap="navigateToPhotoPool">
      管理照片池
    </button>
  </view>

  <view class="section-head">
    <view class="section-title">今日内容</view>
    <view class="section-link" bindtap="navigateToHistory">历史</view>
  </view>

  <view wx:if="{{todayComic}}" class="comic-card" bindtap="openTodayComic">
    <image class="comic-cover" src="{{todayComic.sourceFileID}}" mode="aspectFill"></image>
    <view class="comic-body">
      <view class="comic-date">{{todayComic.date}}</view>
      <view class="comic-title">{{todayComic.title}}</view>
      <view class="comic-summary">{{todayComic.summary}}</view>
    </view>
  </view>

  <view wx:elif="{{latestComic}}" class="comic-card" bindtap="openTodayComic">
    <image class="comic-cover" src="{{latestComic.sourceFileID}}" mode="aspectFill"></image>
    <view class="comic-body">
      <view class="comic-date">最近一次生成</view>
      <view class="comic-title">{{latestComic.title}}</view>
      <view class="comic-summary">{{latestComic.summary}}</view>
    </view>
  </view>

  <view wx:else class="empty-state">
    <view class="empty-title">还没有漫画</view>
    <view class="empty-desc">先上传几张照片，然后生成第一篇今日漫画。</view>
    <button class="inline-btn" bindtap="navigateToPhotoPool">去上传照片</button>
  </view>
</view>
