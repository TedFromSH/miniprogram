page {
  background: #f6f7f2;
  color: #20231d;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 64rpx;
  box-sizing: border-box;
}

.loading,
.empty {
  margin-top: 120rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  background: #fff;
  border: 1rpx solid #e7e8df;
  border-radius: 12rpx;
  color: #74786d;
  font-size: 28rpx;
}

.empty-title {
  color: #20231d;
  font-size: 34rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 14rpx;
  line-height: 1.5;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  margin: 0 4rpx 16rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.selected-photo {
  display: block;
  width: 100%;
  height: 440rpx;
  background: #dfe2d6;
  border-radius: 12rpx;
}

.style-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.style-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  background: #fff;
  border: 2rpx solid #e7e8df;
  border-radius: 10rpx;
}

.style-item-active {
  border-color: #244638;
  background: #eef5e8;
}

.style-name {
  overflow: hidden;
  max-width: 100%;
  font-size: 27rpx;
  font-weight: 700;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.style-hint {
  min-height: 72rpx;
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  color: #8a8f83;
  background: #fff;
  border: 1rpx solid #e7e8df;
  border-radius: 10rpx;
  font-size: 25rpx;
  line-height: 1.45;
}

.style-hint-active {
  color: #66705e;
  background: #fbfcf8;
}

.story-input {
  width: 100%;
  min-height: 220rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  background: #fff;
  border: 1rpx solid #e7e8df;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.55;
}

.story-input-error {
  border-color: #d65b4a;
  background: #fffafa;
}

.story-error {
  margin-top: 12rpx;
  color: #b4473a;
  font-size: 24rpx;
  line-height: 1.45;
}

.input-count {
  margin-top: 10rpx;
  color: #8a8f83;
  text-align: right;
  font-size: 23rpx;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  margin: 18rpx 0 0;
  color: #fff;
  background: #244638;
  border-radius: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.submit-btn-disabled {
  color: rgba(255, 255, 255, 0.76);
  background: #9aa39a;
}

.submit-btn::after {
  border: 0;
}
